#model evaluation
#Model evaluation
# 1. Mean absolute Error: It is the average error
# 2. Mean squared Error: Mean of the squared error (used by the model
# to find the best fit line. It is called as residual sum of squares. 
# 3. Root Mean Squared Error: RMSE simply transforms MSE into same units
# as the variables being compared. making it easier to interpret. 
# 4. R2-Score: popular metric to estimate the performance of regressionabs
#model, 

from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

y_pred = regobj.predict(X_test.reshape(-1, 1))

#Evaluation
print("Mean absolute error: %.2f" % mean_absolute_error(Y_test, y_pred))
print("Mean squared error: %.2f" % mean_squared_error(Y_test, y_pred))
print("Root Mean squared error: %.2f" % np.sqrt(mean_squared_error(Y_test, y_pred)))
print("R2-score: %.2f" % r2_score(Y_test, y_pred))

